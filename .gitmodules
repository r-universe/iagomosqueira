[submodule ".registry"]
	path = .registry
	url = https://github.com/iagomosqueira/iagomosqueira.r-universe.dev
	branch = HEAD
[submodule "FLBRP"]
	path = FLBRP
	url = https://github.com/flr/FLBRP
	branch = devel
[submodule "FLasher"]
	path = FLasher
	url = https://github.com/flr/FLasher
	branch = devel
[submodule "mse"]
	path = mse
	url = https://github.com/flr/mse
	branch = devel
[submodule "msemodules"]
	path = msemodules
	url = https://github.com/flr/msemodules
	branch = devel
[submodule "wmrkdown"]
	path = wmrkdown
	url = https://github.com/iagomosqueira/wmrkdown
